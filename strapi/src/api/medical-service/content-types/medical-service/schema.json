{
  "kind": "collectionType",
  "collectionName": "medical_services",
  "info": {
    "singularName": "medical-service",
    "pluralName": "medical-services",
    "displayName": "Medical Services"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "shortTitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "badge": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "image": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "breadcrumbImage": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "cardDesc": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "hero": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "department-sections.hero",
      "repeatable": false
    },
    "overview": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "department-sections.overview",
      "repeatable": false
    },
    "services": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "department-sections.treated-cases",
      "repeatable": false
    },
    "technology": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "department-sections.treated-cases",
      "repeatable": false
    },
    "highlights": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "department-sections.highlights",
      "repeatable": false
    },
    "cta": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "department-sections.cta",
      "repeatable": false
    },
    "whatsAppNumber": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "doctors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::doctor.doctor",
      "mappedBy": "medical_service"
