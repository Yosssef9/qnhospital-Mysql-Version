{
  "kind": "collectionType",
  "collectionName": "doctors",
  "info": {
    "singularName": "doctor",
    "pluralName": "doctors",
    "displayName": "Doctors"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "clinic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::clinic.clinic",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "inversedBy": "doctors"
    },
    "unit": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::unit.unit",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "inversedBy": "doctors"
    },
    "medical_service": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::medical-service.medical-service",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "inversedBy": "doctors"
    },
    "center": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::center.center",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "inversedBy": "doctors"
    },
    "experience": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "min": 1
    },
    "gender": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "default": "male",
      "enum": ["male", "female"]
    },
    "featured": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": false
    },
    "image": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "doctorRank": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "enum": ["consultant", "specialist"]
    },
    "shortBio": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "specializations": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "doctors.shared-simple-list-item",
      "repeatable": true
    },
    "qualifications": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "doctors.shared-simple-list-item",
      "repeatable": true
    }
  }
}
